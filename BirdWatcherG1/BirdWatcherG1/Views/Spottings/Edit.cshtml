@model BirdWatcherG1.Models.Spotting

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Spotting</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="SpottingId" />
            <div class="form-group">
                <label asp-for="SpottingDescription" class="control-label"></label>
                <input asp-for="SpottingDescription" class="form-control" />
                <span asp-validation-for="SpottingDescription" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="TimeSeen" class="control-label"></label>
                <input asp-for="TimeSeen" class="form-control" />
                <span asp-validation-for="TimeSeen" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ImageUrl" class="control-label"></label>
                <input type="file" name="imageFile" class="form-control" />
                <span asp-validation-for="ImageUrl" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
